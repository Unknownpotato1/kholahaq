rules_version = '2';

// =========================================================================
// GOMEN · Firestore security rules (PRODUCTION-LOCKED)
// =========================================================================
// All client reads/writes are BLOCKED. Every data operation goes through
// the Next.js API routes, which use the Firebase Admin SDK (service account)
// and bypass these rules entirely.
//
// This means:
//   - Visitors can NEVER read accounts, payments, unlockTokens, chats, etc.
//     directly from the browser.
//   - The encrypted `currentPasswordEnc` field is unreachable from the client
//     even if someone finds a document ID.
//   - All data access is mediated by our server-side authentication,
//     payment verification, and rate limiting.
//
// The Admin SDK uses the service account credentials and is NOT subject
// to these rules — it has full read/write access to all collections.
// =========================================================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Block ALL direct client access.
      // The Admin SDK (used by our API routes) bypasses these rules.
      allow read, write: if false;
    }
  }
}
